# Copy this file to .env and fill in real values for local development.
# .env is git-ignored; .env.example is committed as a template.

# Local development database credentials
POSTGRES_USER=nutcracker
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nutcracker
POSTGRES_PORT=5432

# Connection string used by the Go backend
DATABASE_URL=postgres://nutcracker:changeme@localhost:5432/nutcracker?sslmode=disable

# HTTP server listen address
HTTP_ADDR=:8080
