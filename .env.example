# Copy this file to .env and fill in real values for local development.
# .env is git-ignored; .env.example is committed as a template.

# Local development database credentials
POSTGRES_USER=nutcracker
POSTGRES_PASSWORD=changeme
POSTGRES_DB=nutcracker
POSTGRES_PORT=5432

# Connection string used by the Go backend
DATABASE_URL=postgres://nutcracker:changeme@localhost:5432/nutcracker?sslmode=disable

# HTTP server listen address
HTTP_ADDR=:8080

# Public URL of the frontend, used to build links in emails.
APP_BASE_URL=http://localhost:5173

# Mark session cookies Secure (set true when served over HTTPS).
COOKIE_SECURE=false

# Transactional email. Transport priority: SMTP (if SMTP_HOST set) > Resend
# (if RESEND_API_KEY set) > console (logs the email link, for dev).
RESEND_API_KEY=
MAIL_FROM=Nut Cracker <onboarding@resend.dev>

# SMTP (e.g. Gmail with an App Password) — sends to any recipient, no domain
# needed. Set these to use SMTP instead of Resend.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Directory of built frontend files for the Go server to serve. Leave empty
# in local dev (Vite serves the UI); set in production (Docker sets it).
STATIC_DIR=
